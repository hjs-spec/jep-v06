{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jep.org/schemas/jep-ref-0.6.schema.json",
  "title": "JEP Reference",
  "oneOf": [
    {
      "type": "string",
      "pattern": "^[a-z0-9-]+:[0-9a-f]+$"
    },
    {
      "type": "object",
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "value": {},
        "hash": {
          "type": "string",
          "pattern": "^[a-z0-9-]+:[0-9a-f]+$"
        }
      }
    },
    {
      "type": "null"
    }
  ]
}